# ── CROO ───────────────────────────────────────────────────────────────
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_...

# ── AI Provider ─────────────────────────────────────────
# Pick one. Set AI_PROVIDER to match.
AI_PROVIDER=groq          # groq | openai | ollama | gemini | mistral | anthropic

# Groq (free tier — recommended)
GROQ_API_KEY=gsk_...

# OpenAI (paid)
OPENAI_API_KEY=sk-...

# Ollama (local, free — must have Ollama running)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Gemini (free tier available)
GEMINI_API_KEY=...

# Mistral (free tier available)
MISTRAL_API_KEY=...

# Anthropic Claude (paid, claude-haiku is cheapest)
ANTHROPIC_API_KEY=sk-ant-...

# ── Stock media ──────────────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── Cloudflare R2 ────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=videoforge-outputs
# Public domain from the bucket's "Public Development URL" settings page.
# Copy the exact domain it shows (no scheme), e.g. pub-abcd1234ef567890.r2.dev
# or a custom domain like cdn.example.com. If unset, falls back to
# pub-<account_id[:8]>.r2.dev.
CLOUDFLARE_R2_PUBLIC_DOMAIN=

# ── Misc ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
